<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Daftar — BookMySpace</title>
  <link rel="icon" type="image/x-icon" href="/images/logo.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/output.css">
</head>
<body class="min-h-screen bg-white text-[#1E293B] font-sans antialiased">

<div class="relative bg-gradient-to-bl from-[#dcf4ff] via-transparent">
  <div class="max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 mx-auto">

    <!-- Grid -->
    <div class="grid items-center md:grid-cols-2 gap-8 lg:gap-12">

      <!-- Left col -->
      <div>
        <a href="/" class="inline-flex items-center gap-2.5 mb-6">
          <img src="/images/logo.png" alt="BookMySpace" class="h-8 w-8 object-contain" onerror="this.style.display='none'">
          <span class="font-semibold text-xl text-[#001A9E]">BookMySpace</span>
        </a>

        <div class="mt-2 md:mb-12 max-w-2xl">
          <h1 class="mb-4 font-semibold text-[#1E293B] text-4xl lg:text-5xl">
            Pesan ruangan kampus dengan mudah dan transparan.
          </h1>
          <p class="text-gray-500">
            BookMySpace menyederhanakan seluruh alur peminjaman — dari pengecekan ketersediaan, pengajuan surat resmi, hingga konfirmasi admin — dalam satu platform terpusat.
          </p>
        </div>

        <!-- Blockquote (desktop only) -->
        <blockquote class="hidden md:block relative max-w-sm">
          <svg class="absolute top-0 start-0 -translate-x-6 -translate-y-8 size-16 text-gray-200" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M7.39762 10.3C7.39762 11.0733 7.14888 11.7 6.6514 12.18C6.15392 12.6333 5.52552 12.86 4.76621 12.86C3.84979 12.86 3.09047 12.5533 2.48825 11.94C1.91222 11.3266 1.62421 10.4467 1.62421 9.29999C1.62421 8.07332 1.96459 6.87332 2.64535 5.69999C3.35231 4.49999 4.33418 3.55332 5.59098 2.85999L6.4943 4.25999C5.81354 4.73999 5.26369 5.27332 4.84476 5.85999C4.45201 6.44666 4.19017 7.12666 4.05926 7.89999C4.29491 7.79332 4.56983 7.73999 4.88403 7.73999C5.61716 7.73999 6.21938 7.97999 6.69067 8.45999C7.16197 8.93999 7.39762 9.55333 7.39762 10.3ZM14.6242 10.3C14.6242 11.0733 14.3755 11.7 13.878 12.18C13.3805 12.6333 12.7521 12.86 11.9928 12.86C11.0764 12.86 10.3171 12.5533 9.71484 11.94C9.13881 11.3266 8.85079 10.4467 8.85079 9.29999C8.85079 8.07332 9.19117 6.87332 9.87194 5.69999C10.5789 4.49999 11.5608 3.55332 12.8176 2.85999L13.7209 4.25999C13.0401 4.73999 12.4903 5.27332 12.0713 5.85999C11.6786 6.44666 11.4168 7.12666 11.2858 7.89999C11.5215 7.79332 11.7964 7.73999 12.1106 7.73999C12.8437 7.73999 13.446 7.97999 13.9173 8.45999C14.3886 8.93999 14.6242 9.55333 14.6242 10.3Z" fill="currentColor"/>
          </svg>
          <div class="relative z-10">
            <p class="text-xl italic text-[#1E293B]">
              "Proses peminjaman ruangan jadi jauh lebih cepat dan mudah dipantau. Tidak perlu lagi menghubungi admin berkali-kali."
            </p>
          </div>
          <footer class="mt-3">
            <div class="flex items-center gap-x-4">
              <div class="shrink-0">
                <img class="size-8 rounded-full" src="https://images.unsplash.com/photo-1492562080023-ab3db95bfbce?ixlib=rb-4.0.3&auto=format&fit=facearea&facepad=2&w=320&h=320&q=80" alt="Avatar">
              </div>
              <div class="grow">
                <div class="font-semibold text-[#1E293B]">Udin</div>
                <div class="text-xs text-gray-500">Mahasiswa | Universitas Andalas</div>
              </div>
            </div>
          </footer>
        </blockquote>
      </div>
      <!-- End Left Col -->

      <!-- Right col: form card -->
      <div>
        <div class="lg:max-w-lg lg:mx-auto lg:me-0 ms-auto">
          <div class="p-4 sm:p-7 flex flex-col bg-white rounded-2xl shadow-lg">

            <!-- Logo inside card -->
            <div class="flex justify-center mb-5">
              <a href="/" class="inline-flex items-center gap-2.5">
                <img src="/images/logo.png" alt="BookMySpace" class="h-16 w-16 object-contain" onerror="this.style.display='none'">
                <!-- <span class="font-semibold text-xl text-[#001A9E]">BookMySpace</span> -->
              </a>
            </div>

            <div class="text-center">
              <h1 class="block text-2xl font-bold text-[#1E293B]">Buat Akun Baru</h1>
              <p class="mt-2 text-sm text-gray-500">
                Sudah punya akun?
                <a href="/login" class="text-[#001A9E] decoration-2 hover:underline font-medium">
                  Masuk di sini
                </a>
              </p>
            </div>

            <div class="mt-5">

              <!-- Google (placeholder) -->
              <button type="button" class="w-full py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-medium rounded-lg bg-white border border-[#E2E8F0] text-[#1E293B] shadow-sm hover:bg-gray-50 focus:outline-none disabled:opacity-50 disabled:pointer-events-none">
                <svg class="w-4 h-auto" width="46" height="47" viewBox="0 0 46 47" fill="none">
                  <path d="M46 24.0287C46 22.09 45.8533 20.68 45.5013 19.2112H23.4694V27.9356H36.4069C36.1429 30.1094 34.7347 33.37 31.5957 35.5731L31.5663 35.8669L38.5191 41.2719L38.9885 41.3306C43.4477 37.2181 46 31.1669 46 24.0287Z" fill="#4285F4"/>
                  <path d="M23.4694 47C29.8061 47 35.1161 44.9144 39.0179 41.3012L31.625 35.5437C29.6301 36.9244 26.9898 37.8937 23.4987 37.8937C17.2793 37.8937 12.0281 33.7812 10.1505 28.1412L9.88649 28.1706L2.61097 33.7812L2.52296 34.0456C6.36608 41.7125 14.287 47 23.4694 47Z" fill="#34A853"/>
                  <path d="M10.1212 28.1413C9.62245 26.6725 9.32908 25.1156 9.32908 23.5C9.32908 21.8844 9.62245 20.3275 10.0918 18.8588V18.5356L2.75765 12.8369L2.52296 12.9544C0.909439 16.1269 0 19.7106 0 23.5C0 27.2894 0.909439 30.8731 2.49362 34.0456L10.1212 28.1413Z" fill="#FBBC05"/>
                  <path d="M23.4694 9.07688C27.8699 9.07688 30.8622 10.9863 32.5344 12.5725L39.1645 6.11C35.0867 2.32063 29.8061 0 23.4694 0C14.287 0 6.36607 5.2875 2.49362 12.9544L10.0918 18.8588C11.9987 13.1894 17.25 9.07688 23.4694 9.07688Z" fill="#EB4335"/>
                </svg>
                Daftar dengan Google
              </button>

              <!-- Divider -->
              <div class="py-3 flex items-center text-xs text-gray-400 uppercase before:flex-1 before:border-t before:border-[#E2E8F0] before:me-6 after:flex-1 after:border-t after:border-[#E2E8F0] after:ms-6">
                Atau
              </div>

              <!-- Error messages -->
              <% if (typeof errors !== 'undefined' && errors && errors.length) { %>
                <div class="mb-4 p-3 rounded-lg bg-red-50 border border-red-100">
                  <ul class="space-y-1">
                    <% errors.forEach(function(err) { %>
                      <li class="text-sm text-red-700">— <%= err %></li>
                    <% }) %>
                  </ul>
                </div>
              <% } %>

              <!-- Form -->
              <form action="/register" method="POST">
                <div class="grid grid-cols-2 gap-4">

                  <!-- Nama Depan -->
                  <div>
                    <div class="relative">
                      <input
                        type="text"
                        id="first_name"
                        name="first_name"
                        value="<%= typeof old !== 'undefined' && old && old.first_name ? old.first_name : '' %>"
                        class="peer p-3 sm:p-4 block w-full bg-white border border-[#E2E8F0] rounded-lg sm:text-sm text-[#1E293B] placeholder:text-transparent focus:border-[#001A9E] focus:ring-[#001A9E] focus:outline-none focus:pt-6 focus:pb-2 not-placeholder-shown:pt-6 not-placeholder-shown:pb-2 autofill:pt-6 autofill:pb-2 disabled:opacity-50"
                        placeholder="Budi"
                      >
                      <label for="first_name" class="absolute top-0 start-0 p-3 sm:p-4 h-full text-sm truncate pointer-events-none transition ease-in-out duration-100 border border-transparent origin-[0_0] text-[#1E293B] peer-disabled:opacity-50
                        peer-focus:scale-90 peer-focus:translate-x-0.5 peer-focus:-translate-y-1.5 peer-focus:text-gray-500
                        peer-not-placeholder-shown:scale-90 peer-not-placeholder-shown:translate-x-0.5 peer-not-placeholder-shown:-translate-y-1.5 peer-not-placeholder-shown:text-gray-500">
                        Nama Depan
                      </label>
                    </div>
                  </div>

                  <!-- Nama Belakang -->
                  <div>
                    <div class="relative">
                      <input
                        type="text"
                        id="last_name"
                        name="last_name"
                        value="<%= typeof old !== 'undefined' && old && old.last_name ? old.last_name : '' %>"
                        class="peer p-3 sm:p-4 block w-full bg-white border border-[#E2E8F0] rounded-lg sm:text-sm text-[#1E293B] placeholder:text-transparent focus:border-[#001A9E] focus:ring-[#001A9E] focus:outline-none focus:pt-6 focus:pb-2 not-placeholder-shown:pt-6 not-placeholder-shown:pb-2 autofill:pt-6 autofill:pb-2 disabled:opacity-50"
                        placeholder="Santoso"
                      >
                      <label for="last_name" class="absolute top-0 start-0 p-3 sm:p-4 h-full text-sm truncate pointer-events-none transition ease-in-out duration-100 border border-transparent origin-[0_0] text-[#1E293B] peer-disabled:opacity-50
                        peer-focus:scale-90 peer-focus:translate-x-0.5 peer-focus:-translate-y-1.5 peer-focus:text-gray-500
                        peer-not-placeholder-shown:scale-90 peer-not-placeholder-shown:translate-x-0.5 peer-not-placeholder-shown:-translate-y-1.5 peer-not-placeholder-shown:text-gray-500">
                        Nama Belakang
                      </label>
                    </div>
                  </div>

                  <!-- Email -->
                  <div>
                    <div class="relative">
                      <input
                        type="email"
                        id="email"
                        name="email"
                        required
                        value="<%= typeof old !== 'undefined' && old && old.email ? old.email : '' %>"
                        class="peer p-3 sm:p-4 block w-full bg-white border border-[#E2E8F0] rounded-lg sm:text-sm text-[#1E293B] placeholder:text-transparent focus:border-[#001A9E] focus:ring-[#001A9E] focus:outline-none focus:pt-6 focus:pb-2 not-placeholder-shown:pt-6 not-placeholder-shown:pb-2 autofill:pt-6 autofill:pb-2 disabled:opacity-50"
                        placeholder="nama@kampus.ac.id"
                      >
                      <label for="email" class="absolute top-0 start-0 p-3 sm:p-4 h-full text-sm truncate pointer-events-none transition ease-in-out duration-100 border border-transparent origin-[0_0] text-[#1E293B] peer-disabled:opacity-50
                        peer-focus:scale-90 peer-focus:translate-x-0.5 peer-focus:-translate-y-1.5 peer-focus:text-gray-500
                        peer-not-placeholder-shown:scale-90 peer-not-placeholder-shown:translate-x-0.5 peer-not-placeholder-shown:-translate-y-1.5 peer-not-placeholder-shown:text-gray-500">
                        Email
                      </label>
                    </div>
                  </div>

                  <!-- Nomor Telepon -->
                  <div>
                    <div class="relative">
                      <input
                        type="tel"
                        id="phone_number"
                        name="phone_number"
                        value="<%= typeof old !== 'undefined' && old && old.phone_number ? old.phone_number : '' %>"
                        class="peer p-3 sm:p-4 block w-full bg-white border border-[#E2E8F0] rounded-lg sm:text-sm text-[#1E293B] placeholder:text-transparent focus:border-[#001A9E] focus:ring-[#001A9E] focus:outline-none focus:pt-6 focus:pb-2 not-placeholder-shown:pt-6 not-placeholder-shown:pb-2 autofill:pt-6 autofill:pb-2 disabled:opacity-50"
                        placeholder="08xxxxxxxxxx"
                      >
                      <label for="phone_number" class="absolute top-0 start-0 p-3 sm:p-4 h-full text-sm truncate pointer-events-none transition ease-in-out duration-100 border border-transparent origin-[0_0] text-[#1E293B] peer-disabled:opacity-50
                        peer-focus:scale-90 peer-focus:translate-x-0.5 peer-focus:-translate-y-1.5 peer-focus:text-gray-500
                        peer-not-placeholder-shown:scale-90 peer-not-placeholder-shown:translate-x-0.5 peer-not-placeholder-shown:-translate-y-1.5 peer-not-placeholder-shown:text-gray-500">
                        No. Telepon (opsional)
                      </label>
                    </div>
                  </div>

                  <!-- Kata Sandi -->
                  <div class="relative col-span-full">
                    <div class="relative">
                      <input
                        type="password"
                        id="password"
                        name="password"
                        required
                        class="peer p-3 sm:p-4 block w-full bg-white border border-[#E2E8F0] rounded-lg sm:text-sm text-[#1E293B] placeholder:text-transparent focus:border-[#001A9E] focus:ring-[#001A9E] focus:outline-none focus:pt-6 focus:pb-2 not-placeholder-shown:pt-6 not-placeholder-shown:pb-2 autofill:pt-6 autofill:pb-2 disabled:opacity-50"
                        placeholder="••••••••"
                      >
                      <label for="password" class="absolute top-0 start-0 p-3 sm:p-4 h-full text-sm truncate pointer-events-none transition ease-in-out duration-100 border border-transparent origin-[0_0] text-[#1E293B] peer-disabled:opacity-50
                        peer-focus:scale-90 peer-focus:translate-x-0.5 peer-focus:-translate-y-1.5 peer-focus:text-gray-500
                        peer-not-placeholder-shown:scale-90 peer-not-placeholder-shown:translate-x-0.5 peer-not-placeholder-shown:-translate-y-1.5 peer-not-placeholder-shown:text-gray-500">
                        Kata Sandi
                      </label>
                    </div>
                  </div>

                  <!-- Konfirmasi Kata Sandi -->
                  <div class="col-span-full">
                    <div class="relative">
                      <input
                        type="password"
                        id="passwordConfirm"
                        name="passwordConfirm"
                        required
                        class="peer p-3 sm:p-4 block w-full bg-white border border-[#E2E8F0] rounded-lg sm:text-sm text-[#1E293B] placeholder:text-transparent focus:border-[#001A9E] focus:ring-[#001A9E] focus:outline-none focus:pt-6 focus:pb-2 not-placeholder-shown:pt-6 not-placeholder-shown:pb-2 autofill:pt-6 autofill:pb-2 disabled:opacity-50"
                        placeholder="••••••••"
                      >
                      <label for="passwordConfirm" class="absolute top-0 start-0 p-3 sm:p-4 h-full text-sm truncate pointer-events-none transition ease-in-out duration-100 border border-transparent origin-[0_0] text-[#1E293B] peer-disabled:opacity-50
                        peer-focus:scale-90 peer-focus:translate-x-0.5 peer-focus:-translate-y-1.5 peer-focus:text-gray-500
                        peer-not-placeholder-shown:scale-90 peer-not-placeholder-shown:translate-x-0.5 peer-not-placeholder-shown:-translate-y-1.5 peer-not-placeholder-shown:text-gray-500">
                        Konfirmasi Kata Sandi
                      </label>
                    </div>
                  </div>

                </div>
                <!-- End Grid -->

                <!-- Terms -->
                <div class="mt-5 flex items-center gap-x-3">
                  <input
                    id="agree"
                    name="agree"
                    type="checkbox"
                    required
                    class="shrink-0 size-4 bg-transparent border border-[#E2E8F0] rounded text-[#001A9E] focus:ring-0 focus:ring-offset-0 checked:bg-[#001A9E] checked:border-[#001A9E] disabled:opacity-50"
                  >
                  <label for="agree" class="text-sm text-[#1E293B]">
                    Saya menyetujui
                    <a href="/terms" class="text-[#001A9E] decoration-2 hover:underline font-medium">Syarat &amp; Ketentuan</a>
                  </label>
                </div>

                <!-- Submit -->
                <div class="mt-5">
                  <button
                    type="submit"
                    class="w-full py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-medium rounded-lg bg-[#001A9E] border border-[#001A9E] text-white hover:bg-[#0025C7] focus:outline-none focus:bg-[#0025C7] disabled:opacity-50 disabled:pointer-events-none transition-colors"
                  >
                    Buat Akun
                  </button>
                </div>

              </form>
              <!-- End Form -->

            </div>
          </div>
          <!-- End Card -->
        </div>
      </div>
      <!-- End Right Col -->

    </div>
    <!-- End Grid -->

  </div>
</div>

<script src="/js/preline.js"></script>
</body>
</html>
