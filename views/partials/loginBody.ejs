<div class="min-h-screen flex flex-col bg-white">

  <!-- Top bar with logo -->
  <div class="px-6 py-4 border-b border-[#E2E8F0]">
    <a href="/" class="inline-flex items-center gap-2.5">
      <img src="/images/logo.png" alt="BookMySpace" class="h-7 w-7 object-contain" onerror="this.style.display='none'">
      <span class="font-semibold text-lg text-[#001A9E]">BookMySpace</span>
    </a>
  </div>

  <!-- Centered card -->
  <div class="flex-1 flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-md">

      <!-- Error alert -->
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="mb-4 p-3 rounded-lg bg-red-50 border border-red-100 text-sm text-red-700">
          <%= error %>
        </div>
      <% } %>

      <!-- Preline card -->
      <div class="bg-white border border-[#E2E8F0] rounded-xl shadow-sm">
        <div class="p-4 sm:p-7">

          <!-- Header -->
          <div class="text-center">
            <h1 class="block text-2xl font-bold text-[#1E293B]">Masuk</h1>
            <p class="mt-2 text-sm text-gray-500">
              Belum punya akun?
              <a href="/register" class="text-[#001A9E] decoration-2 hover:underline focus:outline-none focus:underline font-medium">
                Daftar di sini
              </a>
            </p>
          </div>

          <div class="mt-5">

            <!-- Google button -->
            <a href="#" class="w-full py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-medium rounded-lg bg-white border border-[#E2E8F0] text-[#1E293B] shadow-sm hover:bg-gray-50 focus:outline-none focus:bg-gray-50 disabled:opacity-50 disabled:pointer-events-none">
              <svg class="w-4 h-auto" width="46" height="47" viewBox="0 0 46 47" fill="none">
                <path d="M46 24.0287C46 22.09 45.8533 20.68 45.5013 19.2112H23.4694V27.9356H36.4069C36.1429 30.1094 34.7347 33.37 31.5957 35.5731L31.5663 35.8669L38.5191 41.2719L38.9885 41.3306C43.4477 37.2181 46 31.1669 46 24.0287Z" fill="#4285F4"/>
                <path d="M23.4694 47C29.8061 47 35.1161 44.9144 39.0179 41.3012L31.625 35.5437C29.6301 36.9244 26.9898 37.8937 23.4987 37.8937C17.2793 37.8937 12.0281 33.7812 10.1505 28.1412L9.88649 28.1706L2.61097 33.7812L2.52296 34.0456C6.36608 41.7125 14.287 47 23.4694 47Z" fill="#34A853"/>
                <path d="M10.1212 28.1413C9.62245 26.6725 9.32908 25.1156 9.32908 23.5C9.32908 21.8844 9.62245 20.3275 10.0918 18.8588V18.5356L2.75765 12.8369L2.52296 12.9544C0.909439 16.1269 0 19.7106 0 23.5C0 27.2894 0.909439 30.8731 2.49362 34.0456L10.1212 28.1413Z" fill="#FBBC05"/>
                <path d="M23.4694 9.07688C27.8699 9.07688 30.8622 10.9863 32.5344 12.5725L39.1645 6.11C35.0867 2.32063 29.8061 0 23.4694 0C14.287 0 6.36607 5.2875 2.49362 12.9544L10.0918 18.8588C11.9987 13.1894 17.25 9.07688 23.4694 9.07688Z" fill="#EB4335"/>
              </svg>
              Masuk dengan Google
            </a>

            <!-- Divider -->
            <div class="py-3 flex items-center text-xs text-gray-400 uppercase before:flex-1 before:border-t before:border-[#E2E8F0] before:me-6 after:flex-1 after:border-t after:border-[#E2E8F0] after:ms-6">
              Atau
            </div>

            <!-- Form -->
            <form action="/login" method="POST">
              <div class="grid gap-y-4">

                <!-- Email -->
                <div>
                  <label for="email" class="block text-sm mb-2 text-[#1E293B]">Alamat Email</label>
                  <div class="relative">
                    <input
                      type="email"
                      id="email"
                      name="email"
                      required
                      autocomplete="email"
                      placeholder="nama@kampus.ac.id"
                      class="py-2.5 sm:py-3 px-4 block w-full bg-white border border-[#E2E8F0] rounded-lg sm:text-sm text-[#1E293B] placeholder:text-gray-400 focus:border-[#001A9E] focus:ring-[#001A9E] focus:outline-none disabled:opacity-50 disabled:pointer-events-none"
                      aria-describedby="email-error"
                    >
                    <div class="hidden absolute inset-y-0 end-0 pointer-events-none pe-3">
                      <svg class="size-5 text-red-500" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zM8 4a.905.905 0 0 0-.9.995l.35 3.507a.552.552 0 0 0 1.1 0l.35-3.507A.905.905 0 0 0 8 4zm.002 6a1 1 0 1 0 0 2 1 1 0 0 0 0-2z"/>
                      </svg>
                    </div>
                  </div>
                  <p class="hidden text-xs text-red-600 mt-2" id="email-error">Masukkan alamat email yang valid.</p>
                </div>
                <!-- End Email -->

                <!-- Password -->
                <div>
                  <div class="flex flex-wrap items-center justify-between gap-2 mb-2">
                    <label for="password" class="block text-sm text-[#1E293B]">Kata Sandi</label>
                    <a href="/forgot-password" class="text-sm text-[#001A9E] decoration-2 hover:underline focus:outline-none focus:underline font-medium">
                      Lupa kata sandi?
                    </a>
                  </div>
                  <div class="relative">
                    <input
                      type="password"
                      id="password"
                      name="password"
                      required
                      autocomplete="current-password"
                      placeholder="Masukkan kata sandi"
                      class="py-2.5 sm:py-3 px-4 block w-full bg-white border border-[#E2E8F0] rounded-lg sm:text-sm text-[#1E293B] placeholder:text-gray-400 focus:border-[#001A9E] focus:ring-[#001A9E] focus:outline-none disabled:opacity-50 disabled:pointer-events-none"
                      aria-describedby="password-error"
                    >
                    <div class="hidden absolute inset-y-0 end-0 pointer-events-none pe-3">
                      <svg class="size-5 text-red-500" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zM8 4a.905.905 0 0 0-.9.995l.35 3.507a.552.552 0 0 0 1.1 0l.35-3.507A.905.905 0 0 0 8 4zm.002 6a1 1 0 1 0 0 2 1 1 0 0 0 0-2z"/>
                      </svg>
                    </div>
                  </div>
                  <p class="hidden text-xs text-red-600 mt-2" id="password-error">Kata sandi minimal 8 karakter.</p>
                </div>
                <!-- End Password -->

                <!-- Remember Me -->
                <div class="flex items-center">
                  <div class="flex">
                    <input
                      id="remember-me"
                      name="remember"
                      type="checkbox"
                      class="shrink-0 size-4 bg-transparent border-[#E2E8F0] rounded text-[#001A9E] focus:ring-0 focus:ring-offset-0 checked:bg-[#001A9E] checked:border-[#001A9E] disabled:opacity-50 disabled:pointer-events-none"
                    >
                  </div>
                  <div class="ms-3">
                    <label for="remember-me" class="text-sm text-[#1E293B]">Ingat saya</label>
                  </div>
                </div>
                <!-- End Remember Me -->

                <!-- Submit -->
                <button
                  type="submit"
                  class="w-full py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-medium rounded-lg bg-[#001A9E] border border-[#001A9E] text-white hover:bg-[#0025C7] focus:outline-none focus:bg-[#0025C7] disabled:opacity-50 disabled:pointer-events-none transition-colors"
                >
                  Masuk
                </button>
                <!-- End Submit -->

              </div>
            </form>
            <!-- End Form -->

          </div>
        </div>
      </div>
      <!-- End Card -->

    </div>
  </div>
</div>
