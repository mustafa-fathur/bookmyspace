{
  "name": "bookmyspace",
  "version": "1.0.0",
  "description": "University room booking system",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "css:build": "npx @tailwindcss/cli -i ./public/css/input.css -o ./public/css/output.css",
    "css:watch": "npx @tailwindcss/cli -i ./public/css/input.css -o ./public/css/output.css --watch",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:seed": "npx sequelize-cli db:seed:all",
    "db:reset": "npx sequelize-cli db:migrate:undo:all && npx sequelize-cli db:migrate && npx sequelize-cli db:seed:all"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mustafa-fathur/bookmyspace.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/mustafa-fathur/bookmyspace/issues"
  },
  "homepage": "https://github.com/mustafa-fathur/bookmyspace#readme",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "connect-session-sequelize": "^7.1.7",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^5.2.1",
    "express-session": "^1.18.1",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.11.0",
    "sequelize": "^6.37.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.0",
    "nodemon": "^3.1.0",
    "sequelize-cli": "^6.6.2",
    "tailwindcss": "^4.1.0"
  }
}
